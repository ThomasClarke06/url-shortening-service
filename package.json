{
  "name": "url-shortening-service",
  "version": "0.0.1",
  "description": "Minimal URL shortening API (NestJS + TypeScript)",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "start": "node dist/main.js",
    "start:dev": "tsc -p tsconfig.json && concurrently -k \"tsc -p tsconfig.json -w --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
